# ===================================
# Event Platform — Environment Variables
# ===================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/event_platform?schema=public"

# API Server
API_PORT=4000
API_URL=http://localhost:4000

# JWT
JWT_SECRET="change-me-to-a-secure-secret"
JWT_EXPIRES_IN="7d"

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@event-platform.com"

# SMS (Adapter — configure provider)
SMS_PROVIDER="mock"
SMS_API_KEY=""
SMS_SENDER=""

# LINE OA
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# QR Code
QR_BASE_URL="http://localhost:3002/checkin"
